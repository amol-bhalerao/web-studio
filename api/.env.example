DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=blog_mfe

# --- XAMPP / WAMP / local phpMyAdmin (often root + empty password) ---
DB_USER=root
DB_PASS=

# --- Docker Compose MySQL from this repo (see docker-compose.yml) ---
# DB_USER=blog
# DB_PASS=blog_secret

JWT_SECRET=replace-with-long-random-secret-minimum-32-characters
JWT_TTL=86400

# * = allow any Origin header. For production you can list comma-separated origins:
# CORS_ORIGIN=https://www.example.com,https://admin.example.com
CORS_ORIGIN=*

# Slim base path override (rare). Leave empty — auto-detected from /api/index.php on shared hosts.
# APP_BASE_PATH=api

# Set to 0 in production (no stack traces in JSON errors).
APP_DEBUG=1
