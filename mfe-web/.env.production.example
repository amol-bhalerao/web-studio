# Copy to .env.production before `npm run build` (optional — sensible defaults exist).

# Absolute API base if the API is on another host or path, e.g.:
# VITE_API_BASE=https://api.example.com/api/v1
# Same-domain Hostinger layout usually needs NO variable (defaults to /api/v1).

# Public site branding (optional)
# VITE_BRAND_NAME=Pyramid International School
# VITE_BRAND_TAGLINE=Excellence in teaching and research
# VITE_BRAND_ADDRESS=Main Road\nCity, ST 12345
# VITE_BRAND_HIGHLIGHTS=NAAC accredited|Student support desk

# Admin panel link from the public “Admin” button (optional).
# Default production: /admin/ — override if admin is on another subdomain:
# VITE_ADMIN_URL=https://admin.example.com/
